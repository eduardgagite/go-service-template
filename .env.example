DB_NAME=service_db
DB_USER=postgres
DB_PASSWORD=password
# disable подходит локально. Для удалённого/managed-Postgres используйте require или verify-full.
DB_SSLMODE=disable
DB_MAX_CONNS=20
DB_MIN_CONNS=2
DB_MAX_CONN_LIFETIME=1h
DB_MAX_CONN_IDLE_TIME=30m
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
# Макс. размер тела запроса в байтах (по умолчанию 4 МиБ), запросов/мин на IP (0 отключает)
# и список CORS-источников через запятую (ограничьте в продакшене).
SERVER_BODY_LIMIT=4194304
SERVER_RATE_LIMIT=100
CORS_ALLOW_ORIGINS=*
# true = человекочитаемые debug-логи (локальная разработка). false = JSON info-логи (продакшен).
DEBUG_MODE=false
# Swagger раскрывает всю поверхность API — держите выключенным в продакшене.
ENABLE_SWAGGER=false
